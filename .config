# OpenWrt x86_64 Config for Docker + Passwall
# Target: x86_64
# Version: 24.10.0

CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_TARGET_MULTIMEDIA=y

# Base System
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_kmod-bridge=y
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-dm=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fuse=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y

# Docker
CONFIG_DOCKER=y
CONFIG_DOCKER_CGROUP_OPTIONS=y
CONFIG_DOCKER_NETWORKD=y
CONFIG_DOCKER_RUN_CONTAINER=y
CONFIG_DOCKER_STO_BTRFS=y
CONFIG_DOCKER_STO_EXT4=y
CONFIG_FEATURE_DOCKER_AUTHORIZED_NETWORKS=y
CONFIG_FEATURE_DOCKER_CONFIG_GLOBAL_OPTIONS=y
CONFIG_FEATURE_DOCKER_CONFIG_NETWORKS=y
CONFIG_FEATURE_DOCKER_CONFIG_VOLUMES=y
CONFIG_PACKAGE_dockerd=y
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_kmod-docker=y

# Passwall (最新版本)
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_passwall=y
CONFIG_PACKAGE_passwall_INCLUDE_ShadowsocksR=y
CONFIG_PACKAGE_passwall_INCLUDE_V2ray=y
CONFIG_PACKAGE_passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_passwall_INCLUDE_Trojan=y
CONFIG_PACKAGE_passwall_INCLUDE_NaiveProxy=y
CONFIG_PACKAGE_passwall_INCLUDE_Trojan-Go=y
CONFIG_PACKAGE_passwall_INCLUDE_ShadowsocksR_Server=y

# Networking
CONFIG_PACKAGE_ip6tables=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_iptables-extra=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-iptunnel=y
CONFIG_PACKAGE_kmod-gre=y
CONFIG_PACKAGE_kmod-ip6 tunnels=y
CONFIG_PACKAGE_kmod-nathelper=y

# OpenClash (alternative to Passwall)
CONFIG_PACKAGE_luci-app-openclash=y

# Additional useful packages
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_bind-dig=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_vim-full=y
CONFIG_PACKAGE_screen=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_bc=y
CONFIG_PACKAGE_tar=y
CONFIG_PACKAGE_gzip=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_block-mount=y

# USB/Filesystem
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb-ohci=y
CONFIG_PACKAGE_kmod-usb-uhci=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_ntfs-3g=y
CONFIG_PACKAGE_exfat-fuse=y

# Image - 8GB
CONFIG_TARGET_ROOTFS_PARTSIZE=8192
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_EXT4_SIZE=8G
